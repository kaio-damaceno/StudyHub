# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env.local e preencha com seus valores

# ========================================
# API Keys (Serviços Externos)
# ========================================

# Gemini API (Google)
# Obtenha em: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=sua_chave_gemini_aqui

# ========================================
# API Base URLs
# ========================================

# URL base para requisições da API (se houver backend)
VITE_API_BASE_URL=http://localhost:3000

# Ambiente (development, staging, production)
VITE_ENV=development

# ========================================
# Configurações de Desenvolvimento
# ========================================

# Debug mode (mostrar logs adicionais)
VITE_DEBUG=false

# ========================================
# Configurações do Electron
# ========================================

# Porta do servidor Vite (usado pelo Electron)
VITE_PORT=5173

# ========================================
# Armazenamento e Banco de Dados
# ========================================

# IndexedDB nome do banco de dados
VITE_DB_NAME=hub_study_browser

# Versão do schema (incrementar quando mudar estrutura)
VITE_DB_VERSION=1

# ========================================
# Integração com Serviços
# ========================================

# Searx instance URL (para buscas)
VITE_SEARX_URL=https://searx.info

# ========================================
# Configurações Gerais
# ========================================

# Tempo de auto-save em milissegundos (padrão: 5000ms = 5s)
VITE_AUTOSAVE_INTERVAL=5000

# Máximo de notas a carregar por vez
VITE_MAX_NOTES_LOAD=100

# ========================================
# NOTAS IMPORTANTES
# ========================================

# ⚠️ NUNCA faça commit de arquivo .env.local
# ⚠️ Variáveis com VITE_ são expostas ao cliente (não use secrets aqui)
# ⚠️ Para dados sensíveis, use backend como proxy
# ⚠️ Ou use ELECTRON mainProcess (não exposto ao renderer)
